# ============================================================
# Beyond-The-Fog — Unified Core Environment Template
# Copy to .env and fill in your values.
# ============================================================

# ── Server ────────────────────────────────────────────────
PORT=3002
NODE_ENV=production

# ── Wallet ────────────────────────────────────────────────
# Must have 0G Newton Testnet tokens for storage uploads + on-chain txs
# Get tokens: https://faucet.0g.ai
PRIVATE_KEY=0x_your_private_key_here
OG_PRIVATE_KEY=0x_your_private_key_here   # same key is fine on testnet

# ── 0G Newton Testnet ─────────────────────────────────────
# storageManager.js rotates through multiple RPCs automatically
RPC_ENDPOINT=https://evmrpc-testnet.0g.ai

# ── Contract Addresses (v2 — deployed 2026-05-15) ─────────
USER_REGISTRY_ADDRESS=0x43195F579aE215d5A90A2811A379B6535f51C599
INFT_CONTRACT_ADDRESS=0xcEBDbCe571b0559bdFD52e47A2fc668A76ed1D67

# ── 0G DA Node ────────────────────────────────────────────
# Run the DA client Docker container locally:
#   docker run -p 51001:51001 0glabs/da-client:latest
# If not running, the server starts fine and skips DA gracefully.
DA_NODE_ADDRESS=localhost:51001

# ── OpenAI fallback (REMOVED — replaced by Gemini) ────────
# ── Gemini fallback (circuit breaker for 0G Compute) ──────
# If 0G Compute is unresponsive, the LLM falls back to Gemini 1.5 Flash.
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── iNFT Stage Image CIDs (0G Storage root hashes) ────────
# Run `npm run upload-assets` to populate these automatically.
NEWBORN_IMAGE_CID=
CURIOUS_IMAGE_CID=
MASTER_IMAGE_CID=
WISE_IMAGE_CID=
SAVIOR_IMAGE_CID=

# ── Item Image CIDs ────────────────────────────────────────
ITEM_LANTERN_CID=
ITEM_AXE_CID=
ITEM_FISHING_ROD_CID=
ITEM_SHOVEL_CID=
ITEM_PICKAXE_CID=
ITEM_HAMMER_CID=
ITEM_BUCKET_CID=
ITEM_SCYTHE_CID=
