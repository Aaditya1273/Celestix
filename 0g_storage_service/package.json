    "@grpc/proto-loader": "^0.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "ethers": "6.13.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "js-base64": "^3.7.5",
    "libsodium-wrappers": "^0.7.15",
    "tweetnacl": "^1.0.3",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "nodemon": "^3.1.10",
    "vitest": "^2.1.9"
  }
