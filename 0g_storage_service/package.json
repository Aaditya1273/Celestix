  "description": "Beyond-The-Fog Unified Core — 0G Newton Testnet backend",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon --watch . --ext js --ignore tests/ --ignore node_modules/ --exec \"node index.js\"",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop beyond-the-fog-core",
    "pm2:restart": "pm2 restart beyond-the-fog-core",
    "pm2:logs": "pm2 logs beyond-the-fog-core",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "upload-assets": "node scripts/upload-assets.js"
  },
  "dependencies": {
    "@0glabs/0g-serving-broker": "^1.0.0-beta.8",
    "@0glabs/0g-ts-sdk": "^0.3.3",
